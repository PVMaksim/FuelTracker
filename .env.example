# =============================================================================
# FuelTracker — шаблон переменных окружения
# Скопировать в .env и заполнить реальными значениями
# НИКОГДА не коммитить .env в Git!
# =============================================================================

# --- База данных ---
POSTGRES_DB=fuel_tracker
POSTGRES_USER=fuel_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Для backend-сервиса (имя контейнера в docker-compose)
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Безопасность API ---
# Генерировать командой: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_generate_strong_key_here

# --- OCR (распознавание чеков) ---
# Получить на: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram уведомления об ошибках ---
# Токен бота: получить у @BotFather
# ID чата: получить у @userinfobot
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# --- Frontend ---
# URL на котором будет работать приложение (с https://)
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
# Тот же API_KEY — используется frontend для запросов
NEXT_PUBLIC_API_KEY=CHANGE_ME_generate_strong_key_here

# --- Домен и SSL ---
DOMAIN=your-domain.com
CERTBOT_EMAIL=your@email.com

# --- Данные автомобиля ---
# Последний пробег из таблицы Numbers (для первого запуска)
INITIAL_ODOMETER=78700
CAR_NAME=Fielder

# --- Режим ---
# true = включить /api/docs (Swagger UI), подробные логи
DEBUG=false
